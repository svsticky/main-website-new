---
import { storyblokEditable } from '@storyblok/astro';
import RichText from './basics/RichText.astro';

const { blok } = Astro.props;
---

<main class="w-3/4 mx-auto py-16 flex flex-col" {...storyblokEditable(blok)}>
  <h1 class="text-4xl font-bold mx-auto mb-8">Medezeggenschap</h1>

  <div class="w-3/4 mx-auto mb-8">
    <RichText content={blok.body_text} />
  </div>

  <div class="border-neutral-300 flex flex-row mb-8">
    <div class="bg-neutral-300 h-px w-full my-auto rounded-full"></div>
    <img src="/exclamation.svg" class="w-7" />
    <div class="bg-neutral-300 h-px w-full my-auto rounded-full"></div>
  </div>

  <ul class="grid grid-cols-2 gap-4">
    {blok.oacs?.map((oac: any) => {
      const url = oac.url?.cached_url || oac.url?.url;
      return (
        <li>
          {url ? (
            <a href={url} target="_blank" rel="noopener noreferrer" class="group flex items-center justify-between gap-2 border border-neutral-200 rounded-xl p-4 hover:-translate-y-1 hover:shadow transition">
              <span class="font-semibold group-hover:text-[var(--brand)] transition">{oac.name}</span>
              <i class="fa-solid fa-arrow-up-right-from-square text-sm text-neutral-400"></i>
            </a>
          ) : (
            <div class="border border-neutral-200 rounded-xl p-4">
              <span class="font-semibold">{oac.name}</span>
            </div>
          )}
        </li>
      );
    })}
  </ul>
</main>
