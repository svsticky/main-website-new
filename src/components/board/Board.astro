---
import { renderRichText, storyblokEditable } from '@storyblok/astro';
import { Image } from 'astro-preload/components';
const { blok } = Astro.props;
import { useStoryblokApi } from '@storyblok/astro';

const storyblokApi = useStoryblokApi();
const current_board = await storyblokApi.getAll('cdn/stories', {
  version: 'draft',
  starts_with: 'vereniging/bestuur',
  content_type: 'board',
  sort_by: "content.board_number:desc:int",
  per_page: 1
});
const is_last = current_board[0].content.board_number === blok.board_number;

blok.board_number = Number(blok.board_number);
---

<main class="w-[92%] sm:w-3/4 mx-auto py-8 min-h-[calc(100vh-160px)]" {...storyblokEditable(blok)}>
  <a href="/vereniging/bestuur" class="text-[var(--brand-dark)] flex flex-row gap-2 group w-max mb-4">
    <i class="my-auto fas fa-arrow-left group-hover:-translate-x-1 transition-transform"></i>
    <span class="group-hover:underline">Terug naar het overzicht</span>
  </a>

  <div class="bg-white shadow rounded-2xl p-8 mb-8 border border-neutral-100">
    <div class="mb-6">
      <h1 class="text-3xl font-extrabold" style={{ color: blok.colour }}>
        {is_last ? "Huidig bestuur" : "Bestuur"} {blok.board_number}
      </h1>
      {!!blok.year && <p class="text-neutral-500">{blok.year}</p>}
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
      <Image url={blok.photo.filename} class="w-full rounded-xl object-cover aspect-video" alt="Bestuursfoto" />

      <div class="flex flex-col gap-6">
        <div>
          <h3 class="text-xl font-extrabold mb-1" style={{ color: blok.colour }}>O.d.z.</h3>
          <p class="italic">"{blok.zinspreuk}"</p>
        </div>
        <div>
          <h3 class="text-xl font-extrabold mb-1" style={{ color: blok.colour }}>Bestuursleden</h3>
          <div set:html={renderRichText(blok.board_members)}></div>
        </div>
      </div>
    </div>

    {!!blok.members?.length &&
      <div class="mt-10 flex flex-col gap-6">
        {blok.members.map((member: any, idx: number) => (
          <a href={member.linkedin_url.cached_url} target="_blank" rel="noopener noreferrer" class="group block">
            <div class={`flex flex-col ${idx % 2 === 0 ? "md:flex-row" : "md:flex-row-reverse"} items-center gap-6 rounded-xl border border-neutral-200 p-4`}>
              <img
                src={member.photo.filename}
                alt={member.name}
                class="w-32 h-32 shrink-0 rounded-full object-cover border-4 transition group-hover:-translate-y-1 group-hover:shadow-lg"
                style={{ "border-color": blok.colour }}
              />
              <div class={`text-center ${idx % 2 === 0 ? "md:text-left" : "md:text-right"}`}>
                <h4 class="font-extrabold text-lg" style={{ color: blok.colour }}>
                  {member.name}{!!member.function && ` - ${member.function}`}
                </h4>
                <p class="mt-1 text-neutral-700">{member.bio}</p>
              </div>
            </div>
          </a>
        ))}
      </div>}
  </div>
</main>
