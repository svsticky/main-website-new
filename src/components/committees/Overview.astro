  <div class="mt-8 col-span-3">
    <ul class="grid grid-cols-3 gap-8">
      {committees.map(committee =>
        <a href={`/vereniging/commissies/${committee.slug}`} class="grid border border-neutral-300 rounded-xl overflow-hidden hover:-translate-y-1 hover:shadow transition">
          <li class="flex flex-col h-full">
            <img class="w-full h-auto aspect-square object-contain border-neutral-300 border-b" src={committee.content.logo.filename} />
            <h3 class="font-semibold text-xl text-center py-4 hyphens-auto my-auto" lang="nl">{committee.content.name}</h3>
