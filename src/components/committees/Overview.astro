---
import { storyblokEditable, useStoryblokApi } from "@storyblok/astro";

const { blok } = Astro.props;

const storyblokApi = useStoryblokApi();
const stories = await storyblokApi.getAll('cdn/stories', {
  version: 'draft',
  starts_with: 'vereniging/commissies',
  content_type: 'committee',
  sort_by: "name"
});

const committees = stories.filter(story => story.content.type === "com");
const groups = stories.filter(story => story.content.type === "wer");
const societies = stories.filter(story => story.content.type === "dis");

