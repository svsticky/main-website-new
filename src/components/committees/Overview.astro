    <h2 class="mx-auto text-2xl font-bold mb-8 mt-24">Disputen</h2>
    <p class="text-center mb-8">Een werkgroep is net als een commissie, maar hoeft geen activiteiten te organiseren. Daarom dienen de meeste werkgroepen ter ondersteuning van de vereniging en hebben regelmatige gezellige werkmomenten.</p>
    <div class="border-neutral-300 flex flex-row">
      <div class="bg-neutral-300 h-px w-full my-auto rounded-full"></div>
      <img src="/exclamation.svg" class="w-7" />
      <div class="bg-neutral-300 h-px w-full my-auto rounded-full"></div>
    </div>
    <ul class="grid grid-cols-3 gap-8 mt-8">
      {societies.map(committee =>
        <a href={`/vereniging/commissies/${committee.slug}`} class="flex border border-neutral-300 rounded-xl overflow-hidden hover:-translate-y-1 hover:shadow transition">
          <li class="flex flex-col w-full">
            <img class="w-full h-auto aspect-square object-contain border-neutral-300 border-b" src={committee.content.logo.filename} />
            <h3 class="w-full font-semibold text-xl text-center py-4 hyphens-auto my-auto" lang="nl">{committee.content.name}</h3>
