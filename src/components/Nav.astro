---
const { language, slug } = Astro.props;

const menus = [
	{
		title: { nl: 'Vereniging', en: 'Association' },
		submenu: [
			{ title: { nl: 'Activiteiten', en: 'Activities' }, to: '/vereniging/activiteiten' },
			{ title: { nl: 'Bestuur', en: 'Board' }, to: '/vereniging/bestuur' },
			{ title: { nl: 'Commissies', en: 'Committees' }, to: '/vereniging/commissies' },
			{ title: { nl: 'Contact', en: 'Contact' }, to: '/vereniging/contact' },
			{ title: { nl: 'Disputen', en: 'Societies' }, to: '/vereniging/disputen' },
			{ title: { nl: 'Huisstijl', en: 'Branding' }, to: '/vereniging/huisstijl' },
      { title: { nl: "Leden van Verdienste", en: "Honary members" }, to: "/vereniging/leden-van-verdienste" },
			{ title: { nl: 'Over ons', en: 'About us' }, to: '/vereniging/over-ons' },
      { title: { nl: "Sociale veiligheid", en: "Social safety" }, to: "/vereniging/vcp" },
		],
	},
	{
		title: { nl: 'Studie', en: "Study" },
		submenu: [
			{ title: { nl: 'Medezeggenschap', en: "Representatives" }, to: '/studie/medezeggenschap' },
			{ title: { nl: 'OER', en: "EER" }, to: '/studie/oer' },
			{ title: { nl: 'Boekverkoop', en: "Books" }, to: 'https://svsticky.nl/boeken' },
		],
	},
	{
		title: { nl: 'Carriere', en: "Career" },
		submenu: [
			{ title: { nl: 'Partners', en: "Partners" }, to: '/carriere/partners' },
			{ title: { nl: 'Samenwerking', en: "Collaboration" }, to: '/carriere/samenwerking' },
			{ title: { nl: 'Vacatures', en: "Vacancies" }, to: '/carriere/vacatures' },
		],
	},
	{ title: { nl: 'Nieuws', en: 'News' }, to: '/nieuws' },
	{ title: { nl: 'Links', en: "Links" }, to: '/links' },
];

const buttons = [
	{ title: { nl: 'Koala', en: 'Koala' }, to: 'https://koala.svsticky.nl', type: 'button' },
	{ title: { nl: 'Word lid', en: 'Join Sticky' }, to: 'https://wordlid.svsticky.nl', type: 'button' },
];

const languages = [
  { text: "Nederlands", prefix: "" },
  { text: "English", prefix: "/en" }
];
if (language !== "en") languages.reverse();
---

<nav class="px-4 md:px-6 flex items-center h-16 justify-between bg-[var(--brand)] shadow-md relative z-50">
  <div id="dies-confetti" class="pointer-events-none absolute top-full left-0 w-full h-0 overflow-visible"></div>
  <div class="flex items-center gap-10">
    <a href="/" class="py-2 relative">
      <img
        class="h-10 md:h-12"
        src="https://public.svsticky.nl/logos/logo_compact_outline_wit.svg"
        alt="Logo SV Sticky"
      />
    </a>
    <ul class="hidden lg:flex h-full flex-row items-center gap-8">
      {
        menus.map((menu) => (
          <li class="my-auto relative">
            {menu.to ? (
              <a href={`${language ? `/${language}` : ""}${menu.to}`} class="text-white hover:text-white/80 transition">
                {menu.title[language === undefined ? "nl" : "en"]}
              </a>
            ) : (
              <a data-menu class="text-white hover:text-white/80 transition cursor-pointer select-none flex flex-row gap-1">
                {menu.title[language === undefined ? "nl" : "en"]}
                <i class="fa-solid fa-caret-down transition-transform my-auto" />
              </a>
            )}
            {menu.submenu && (
              <ul
                class="absolute top-8 left-1/2 -translate-x-1/2 -translate-y-1 flex flex-col bg-white border border-neutral-200 shadow-lg rounded-xl text-center z-50 px-4 py-1 w-max opacity-0 pointer-events-none transition-all duration-200"
              >
                {menu.submenu.map((submenu) => (
                  <li class="not-last:border-b not-last:border-neutral-200">
                    <a
                      class="w-full inline-block py-2 hover:text-[var(--brand)] transition"
                      href={`${language && !submenu.to.startsWith('http') ? `/${language}` : ""}${submenu.to}`}
                    >
                      {submenu.title[language === undefined ? "nl" : "en"]}
                      {" "}
                      {submenu.to.startsWith('http') && (
                        <i class="text-sm fa-solid fa-arrow-up-right-from-square" />
                      )}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))
      }
    </ul>
  </div>

  <div class="flex items-center gap-4">
    <ul class="hidden lg:flex h-full flex-row items-center gap-4">
      {
        buttons.map((button) => (
          <li class="my-auto">
            <a
              href={button.to}
              class="text-[var(--brand)] bg-white rounded-lg px-4 py-2 inline-block hover:-translate-y-0.5 hover:shadow transition"
            >
              {button.title[language === undefined ? "nl" : "en"]}
            </a>
          </li>
        ))
      }
    </ul>

    <button id="mobile-menu-toggle" type="button" class="lg:hidden text-white text-2xl w-8 h-8 flex items-center justify-center" aria-label="Menu" aria-expanded="false">
      <i class="fa-solid fa-bars"></i>
    </button>
  </div>
</nav>

<div id="mobile-menu" class="hidden lg:hidden fixed inset-x-0 top-16 bg-white z-40 max-h-[calc(100dvh-4rem)] overflow-y-auto overscroll-contain shadow-lg">
  <ul class="flex flex-col divide-y divide-neutral-200 border-b border-neutral-200">
    {
      menus.map((menu) => (
        <li>
          {menu.to ? (
            <a href={menu.to} class="block px-6 py-4 font-semibold text-neutral-800">
              {menu.title}
            </a>
          ) : (
            <div>
              <button type="button" data-mobile-menu class="w-full flex justify-between items-center px-6 py-4 font-semibold text-neutral-800">
                {menu.title}
                <i class="fa-solid fa-caret-down transition-transform" />
              </button>
              <ul class="hidden flex-col bg-neutral-50">
                {menu.submenu?.map((submenu) => (
                  <li class="not-last:border-b not-last:border-neutral-200">
                    <a href={submenu.to} class="block px-10 py-3 text-neutral-600">
                      {submenu.title}
                      {" "}
                      {submenu.to.startsWith('http') && (
                        <i class="text-xs fa-solid fa-arrow-up-right-from-square" />
                      )}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </li>
      ))
    }
    <li class="my-auto relative">
      <button data-menu class="text-black hover:text-(--brand) cursor-pointer bg-white rounded-lg px-4 py-2 inline-block">
        <i class="fas fa-globe"></i>
      </button>
      <ul
        class="absolute top-12 right-0 -translate-y-1 flex flex-col bg-white border border-neutral-200 shadow-lg rounded-xl text-center z-50 px-4 py-1 w-max opacity-0 pointer-events-none transition-all duration-200"
      >
        {languages.map(lang => (
          <li class="not-last:border-b not-last:border-neutral-200">
            <a
              class="w-full inline-block py-2 hover:text-[var(--brand)] transition"
              href={`${lang.prefix}/${slug || ""}`}
            >{lang.text}</a>
          </li>
        ))}
      </ul>
    </li>
  </ul>

  <div class="flex flex-col gap-3 p-6">
    {
      buttons.map((button) => (
        <a
          href={button.to}
          class="text-center text-[var(--brand)] bg-neutral-100 border border-[var(--brand)] rounded-lg px-4 py-3 font-semibold"
        >
          {button.title}
        </a>
      ))
    }
  </div>
</div>

<script>
	let opened_submenu: HTMLElement | null = null;

	function close_menu(menu: HTMLElement) {
		const submenu = menu.nextElementSibling as HTMLElement;

		submenu.classList.add('opacity-0', 'pointer-events-none', '-translate-y-1');

		const icon = menu.querySelector('.fa-solid') as HTMLElement | undefined;
    if (icon) {
      icon.style.rotate = '0deg';
      icon.style.translate = '0';
    }
	}

	function open_menu(menu: HTMLElement) {
		const submenu = menu.nextElementSibling as HTMLElement;

		if (opened_submenu)
			close_menu(opened_submenu.querySelector('a[data-menu], button[data-menu]')!);
		opened_submenu = menu.parentElement;

		submenu.classList.remove('opacity-0', 'pointer-events-none', '-translate-y-1');

		const icon = menu.querySelector('.fa-solid') as HTMLElement | undefined;
    if (icon) {
      icon.style.rotate = '180deg';
      icon.style.translate = '0 2px';
    }
	}

	function toggle_menu(menu: HTMLElement) {
		const submenu = menu.nextElementSibling as HTMLElement;
		submenu.classList.contains('opacity-0') ? open_menu(menu) : close_menu(menu);
	}

	const menus = Array.from(
		document.querySelectorAll('a[data-menu], button[data-menu]'),
	) as HTMLElement[];
	for (const menu of menus) {
		menu.addEventListener('click', () => {
			toggle_menu(menu);
		});
	}

	document.addEventListener('click', (e) => {
		const target = e.target as HTMLElement;
		if (opened_submenu && !opened_submenu.contains(target))
			close_menu(opened_submenu.querySelector('a[data-menu], button[data-menu]')!);
	});

	const mobile_toggle = document.getElementById('mobile-menu-toggle') as HTMLButtonElement;
	const mobile_menu = document.getElementById('mobile-menu') as HTMLElement;
	const mobile_icon = mobile_toggle.querySelector('i') as HTMLElement;

	function set_mobile_menu(open: boolean) {
		mobile_menu.classList.toggle('hidden', !open);
		mobile_toggle.setAttribute('aria-expanded', String(open));
		mobile_icon.classList.toggle('fa-bars', !open);
		mobile_icon.classList.toggle('fa-xmark', open);
		document.body.classList.toggle('overflow-hidden', open);
	}

	mobile_toggle.addEventListener('click', () => {
		set_mobile_menu(mobile_menu.classList.contains('hidden'));
	});

	for (const submenu_toggle of document.querySelectorAll('#mobile-menu [data-mobile-menu]')) {
		submenu_toggle.addEventListener('click', () => {
			const submenu_list = submenu_toggle.nextElementSibling as HTMLElement;
			const icon = submenu_toggle.querySelector('.fa-solid') as HTMLElement;
			const opening = submenu_list.classList.contains('hidden');

			submenu_list.classList.toggle('hidden', !opening);
			submenu_list.classList.toggle('flex', opening);
			icon.style.rotate = opening ? '180deg' : '0deg';
		});
	}

	window.matchMedia('(min-width: 1024px)').addEventListener('change', (e) => {
		if (e.matches) set_mobile_menu(false);
	});

	const DIES_COLOURS = ['#ffffff', '#fde047', '#f472b6', '#60a5fa', '#fa6b20'];

	function is_dies_week(date: Date) {
		return date.getMonth() === 4 && date.getDate() >= 15 && date.getDate() <= 21;
	}

	function launch_dies_confetti() {
		const container = document.getElementById('dies-confetti');
		if (!container) return;

		for (let i = 0; i < 130; i++) {
			const piece = document.createElement('span');
			const colour = DIES_COLOURS[Math.floor(Math.random() * DIES_COLOURS.length)];
			const left = Math.random() * 100;
			const delay = Math.random() * 0.6;
			const duration = 1.6 + Math.random() * 1.2;
			const rotation = 360 + Math.random() * 360;
			const drift = (Math.random() - 0.5) * 4;
			const size = 5 + Math.random() * 5;

			piece.style.position = 'absolute';
			piece.style.top = '0';
			piece.style.left = `${left}%`;
			piece.style.width = `${size}px`;
			piece.style.height = `${size * 1.6}px`;
			piece.style.background = colour;
			piece.style.borderRadius = '1px';
			piece.style.opacity = '0';
			piece.style.animation = `dies-confetti-fall ${duration}s ease-in ${delay}s forwards`;
			piece.style.setProperty('--rotation', `${rotation}deg`);
			piece.style.setProperty('--drift', `${drift}rem`);

			container.appendChild(piece);
		}

		setTimeout(() => container.replaceChildren(), 3200);
	}

	if (is_dies_week(new Date())) launch_dies_confetti();
</script>

<style is:global>
	@keyframes dies-confetti-fall {
		0% {
			opacity: 1;
			transform: translate(0, 0) rotate(0deg);
		}
		100% {
			opacity: 0;
			transform: translate(var(--drift), 4.5rem) rotate(var(--rotation));
		}
	}
</style>
