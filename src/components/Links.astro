---
import { storyblokEditable } from '@storyblok/astro';

const { blok } = Astro.props;
---

<main class="w-[92%] sm:w-3/4 mx-auto py-16 flex flex-col" {...storyblokEditable(blok)}>
  <h1 class="text-4xl font-bold mb-8">Externe links</h1>

  <ul class="grid grid-cols-2 sm:grid-cols-3 gap-4">
    {blok.links?.map((link: any) => (
      <a href={link.url} target="_blank" rel="noopener noreferrer" class="group block">
        <li class="flex flex-col sm:flex-row items-center sm:items-start text-center sm:text-left gap-4 h-full border border-neutral-200 rounded-xl p-4 group-hover:-translate-y-1 group-hover:shadow transition">
          <div
            class="w-12 h-12 shrink-0 rounded-lg flex items-center justify-center"
            style={{ background: `${link.icon_colour}33`, color: link.icon_colour }}
          >
            <i class={`${link.icon} text-xl`}></i>
          </div>
          <div>
            <h3 class="font-bold text-lg flex items-center justify-center sm:justify-start gap-1.5">
              {link.name}
              <i class="fa-solid fa-arrow-up-right-from-square text-xs text-neutral-400"></i>
            </h3>
            <p class="text-sm text-neutral-600 mt-1">{link.description}</p>
          </div>
        </li>
      </a>
    ))}
  </ul>
</main>
