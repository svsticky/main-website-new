---
import { storyblokEditable } from '@storyblok/astro';
import RichText from './basics/RichText.astro';

const { blok } = Astro.props;

const LOGOS = [
  {
    name: "Kop-logo",
    description: "Voornamelijk gebruikt op Sticky merchandise of in handtekeningen van mails.",
    color: { svg: "https://public.svsticky.nl/logos/hoofd_outline_kleur.svg", png: "https://public.svsticky.nl/logos/hoofd_outline_kleur.png" },
    black: { svg: "https://public.svsticky.nl/logos/hoofd_outline_zwart.svg", png: "https://public.svsticky.nl/logos/hoofd_outline_zwart.png" },
    white: { svg: "https://public.svsticky.nl/logos/hoofd_outline_wit.svg", png: "https://public.svsticky.nl/logos/hoofd_outline_wit.png" },
  },
  {
    name: "Compact logo",
    description: "Gebruikt op bepaalde merchandise en activiteitenposters.",
    color: { svg: "https://public.svsticky.nl/logos/logo_compact_outline_kleur.svg", png: "https://public.svsticky.nl/logos/logo_compact_outline_kleur.png" },
    black: { svg: "https://public.svsticky.nl/logos/logo_compact_outline_zwart.svg", png: "https://public.svsticky.nl/logos/logo_compact_outline_zwart.png" },
    white: { svg: "https://public.svsticky.nl/logos/logo_compact_outline_wit.svg", png: "https://public.svsticky.nl/logos/logo_compact_outline_wit.png" },
  },
  {
    name: "Volledig logo",
    description: "Gereserveerd voor externe doeleinden, zoals bedrijven en de universiteit.",
    color: { svg: "https://public.svsticky.nl/logos/logo_outline_kleur.svg", png: "https://public.svsticky.nl/logos/logo_outline_kleur.png" },
    black: { svg: "https://public.svsticky.nl/logos/logo_outline_zwart.svg", png: "https://public.svsticky.nl/logos/logo_outline_zwart.png" },
    white: { svg: "https://public.svsticky.nl/logos/logo_outline_wit.svg", png: "https://public.svsticky.nl/logos/logo_outline_wit.png" },
  },
];

function hexToRgb(hex: string) {
  const clean = (hex || '#000000').replace('#', '');
  const bigint = parseInt(clean, 16);
  return { r: (bigint >> 16) & 255, g: (bigint >> 8) & 255, b: bigint & 255 };
}

function rgbToCmyk(r: number, g: number, b: number) {
  if (r === 0 && g === 0 && b === 0) return { c: 0, m: 0, y: 0, k: 100 };
  const rp = r / 255, gp = g / 255, bp = b / 255;
  const k = 1 - Math.max(rp, gp, bp);
  const c = Math.round(((1 - rp - k) / (1 - k)) * 100);
  const m = Math.round(((1 - gp - k) / (1 - k)) * 100);
  const y = Math.round(((1 - bp - k) / (1 - k)) * 100);
  return { c, m, y, k: Math.round(k * 100) };
}

const rgb = hexToRgb(blok.primary_colour);
const cmyk = rgbToCmyk(rgb.r, rgb.g, rgb.b);

const specs = [
  { label: 'Formaat', value: blok.poster_format },
  { label: 'Resolutie', value: blok.poster_resolution },
  { label: 'Orientatie', value: blok.poster_orientation },
  { label: 'Bestandstype', value: blok.poster_filetype },
  { label: 'Taal', value: blok.poster_language },
].filter(spec => !!spec.value);
---

<main class="w-3/4 mx-auto py-16 flex flex-col" {...storyblokEditable(blok)}>
  <h1 class="text-4xl font-bold mx-auto mb-8">Huisstijl</h1>
  <p class="w-3/4 mx-auto text-center mb-8">Gebruik je het logo of de kleuren van Sticky voor een poster, presentatie of ander materiaal? Hieronder vind je alles wat je nodig hebt: logo's, kleuren, typografie en de eisen voor posters.</p>

  <div class="border-neutral-300 flex flex-row mb-8">
    <div class="bg-neutral-300 h-px w-full my-auto rounded-full"></div>
    <img src="/exclamation.svg" class="w-7" />
    <div class="bg-neutral-300 h-px w-full my-auto rounded-full"></div>
  </div>

  <h2 class="mx-auto text-2xl font-bold">Logo's</h2>
  <p class="w-3/4 mx-auto text-center mb-8">Elk logo heeft een eigen toepassing: van merchandise en mailhandtekeningen tot posters en externe promotie. Klik op een variant om 'm te downloaden.</p>

  <div class="flex flex-col gap-6 mb-16">
    {LOGOS.map((logo) => (
      <div class="border border-neutral-200 rounded-xl p-6 flex flex-col gap-6">
        <div>
          <h3 class="font-bold text-xl">{logo.name}</h3>
          <p class="text-sm text-neutral-600 mt-1">{logo.description}</p>
        </div>
        <div class="grid grid-cols-3 gap-6">
          <div class="flex flex-col items-center gap-2">
            <div class="w-full aspect-square rounded-lg border border-neutral-200 bg-white flex items-center justify-center p-8">
              <img src={logo.color.svg} class="max-w-full max-h-full huisstijl-logo" alt={`${logo.name} - kleur`} />
            </div>
            <div class="flex gap-2">
              <a href={logo.color.png} download target="_blank" rel="noopener noreferrer" class="text-xs px-2 py-1 rounded border border-neutral-300 hover:bg-neutral-100 transition">PNG</a>
              <a href={logo.color.svg} download target="_blank" rel="noopener noreferrer" class="text-xs px-2 py-1 rounded border border-neutral-300 hover:bg-neutral-100 transition">SVG</a>
            </div>
          </div>
          <div class="flex flex-col items-center gap-2">
            <div class="w-full aspect-square rounded-lg border border-neutral-200 bg-white flex items-center justify-center p-8">
              <img src={logo.black.svg} class="max-w-full max-h-full huisstijl-logo" alt={`${logo.name} - zwart`} />
            </div>
            <div class="flex gap-2">
              <a href={logo.black.png} download target="_blank" rel="noopener noreferrer" class="text-xs px-2 py-1 rounded border border-neutral-300 hover:bg-neutral-100 transition">PNG</a>
              <a href={logo.black.svg} download target="_blank" rel="noopener noreferrer" class="text-xs px-2 py-1 rounded border border-neutral-300 hover:bg-neutral-100 transition">SVG</a>
            </div>
          </div>
          <div class="flex flex-col items-center gap-2">
            <div class="w-full aspect-square rounded-lg border border-neutral-200 bg-neutral-800 flex items-center justify-center p-8">
              <img src={logo.white.svg} class="max-w-full max-h-full huisstijl-logo" alt={`${logo.name} - wit`} />
            </div>
            <div class="flex gap-2">
              <a href={logo.white.png} download target="_blank" rel="noopener noreferrer" class="text-xs px-2 py-1 rounded border border-neutral-300 hover:bg-neutral-100 transition">PNG</a>
              <a href={logo.white.svg} download target="_blank" rel="noopener noreferrer" class="text-xs px-2 py-1 rounded border border-neutral-300 hover:bg-neutral-100 transition">SVG</a>
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>

  <h2 class="mx-auto text-2xl font-bold">Kleuren</h2>
  <p class="w-3/4 mx-auto text-center mb-8">Oranje is de kleur van de vereniging, maar voor promotiemateriaal werkt een aanvullend kleurenpalet vaak beter. Tools als <a class="text-blue-500 hover:underline" href="https://coolors.co" target="_blank" rel="noopener noreferrer">Coolors</a> en het <a class="text-blue-500 hover:underline" href="https://color.adobe.com" target="_blank" rel="noopener noreferrer">Adobe Color Wheel</a> helpen om een passend palet te kiezen.</p>

  <div class="flex flex-row gap-6 items-center border border-neutral-200 rounded-xl overflow-hidden mb-16">
    <div class="w-40 h-40 shrink-0" style={{ background: blok.primary_colour }}></div>
    <div class="flex flex-col gap-1 p-6">
      <span class="font-bold text-lg mb-1">Bestuurskleur</span>
      <span>HEX: {blok.primary_colour?.toUpperCase()}</span>
      <span>RGB: {rgb.r}, {rgb.g}, {rgb.b}</span>
      <span>CMYK: {cmyk.c}, {cmyk.m}, {cmyk.y}, {cmyk.k}</span>
    </div>
  </div>

  <h2 class="mx-auto text-2xl font-bold">Typografie</h2>
  <div class="w-3/4 mx-auto text-center mb-16">
    <RichText content={blok.typography_text} />
  </div>

  <h2 class="mx-auto text-2xl font-bold mb-8">Poster-specificaties</h2>

  {!!specs.length &&
    <div class="grid gap-4 mb-8" style={{ "grid-template-columns": `repeat(${specs.length}, minmax(0, 1fr))` }}>
      {specs.map(spec => (
        <div class="border border-neutral-200 rounded-xl p-4 text-center">
          <span class="block text-xs text-neutral-500">{spec.label}</span>
          <span class="font-bold">{spec.value}</span>
        </div>
      ))}
    </div>
  }

  <div class="grid grid-cols-2 gap-8">
    <div>
      <h3 class="font-bold text-xl mb-2">Activiteitenposters</h3>
      <RichText content={blok.activity_poster_text} />
    </div>
    <div>
      <h3 class="font-bold text-xl mb-2">Externe & onderwijsposters</h3>
      <RichText content={blok.external_poster_text} />
    </div>
  </div>
</main>

<script>
  let click_times: number[] = [];
  const logos = document.querySelectorAll<HTMLImageElement>('.huisstijl-logo');

  function trigger_spin() {
    logos.forEach((img) => img.classList.add('huisstijl-spin'));
  }

  logos.forEach((img) => {
    img.addEventListener('click', () => {
      const now = Date.now();
      click_times = click_times.filter((t) => now - t < 3000);
      click_times.push(now);
      if (click_times.length >= 10) {
        click_times = [];
        trigger_spin();
      }
    });

    img.addEventListener('animationend', () => img.classList.remove('huisstijl-spin'));
  });
</script>

<style is:global>
  @keyframes huisstijl-spin {
    0% { transform: rotate(0deg) scale(1); }
    50% { transform: rotate(720deg) scale(1.15); }
    100% { transform: rotate(1080deg) scale(1); }
  }

  .huisstijl-spin {
    animation: huisstijl-spin 1.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
</style>
