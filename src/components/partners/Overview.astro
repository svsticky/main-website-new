---
import { renderRichText, storyblokEditable } from '@storyblok/astro';
const { blok, language } = Astro.props;

import { useStoryblokApi } from '@storyblok/astro';
import Separator from '../basics/Separator.astro';

const storyblokApi = useStoryblokApi();
const partners = await storyblokApi.getAll('cdn/stories', {
  version: 'draft',
  starts_with: 'carriere/partners',
  content_type: 'partner',
  sort_by: "name",
  language
});

const main_partners = partners.filter(partner => partner.content.is_main);
const regular_partners = partners.filter(partner => !partner.content.is_main);
---

<div {...storyblokEditable(blok)}>
  {!!main_partners.length && <>
    <h2 class="font-bold text-2xl text-center">
      {main_partners.length > 1
        ? (language === undefined ? "Hoofdpartners" : "Main partners")
        : (language === undefined ? "Hoofdpartner" : "Main partner")}
    </h2>
    <ul class="flex flex-col gap-4">
      {main_partners.map((partner: any) =>
        <a href={`/${language === undefined ? "" : `${language}/`}carriere/partners/${partner.slug}`}>
          <li class="flex flex-col sm:flex-row border border-neutral-300 rounded-xl overflow-hidden">
            <img class="w-full sm:w-1/6 h-32 sm:h-auto aspect-square object-contain" src={partner.content.logo.filename} />
            <div class="flex flex-col gap-4 p-4 border-t sm:border-t-0 sm:border-l border-neutral-300">
              <h3 class="font-bold text-xl">{partner.content.name}</h3>
              <div set:html={renderRichText(partner.content.main_text)}></div>
            </div>
          </li>
        </a>
      )}
    </ul>

    <Separator />
  </>}

  {!!main_partners.length && <h2 class="font-bold text-2xl text-center">
      {language === undefined ? "Reguliere partners" : "Regular partners"}
    </h2>}
  <ul class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4">
    {regular_partners.map((partner: any) =>
      <li>
        <a href={`/${language === undefined ? "" : `${language}/`}carriere/partners/${partner.slug}`} class="group flex flex-col h-full border border-neutral-200 rounded-xl overflow-hidden hover:-translate-y-1 hover:shadow-lg hover:border-[var(--brand)] transition">
          <div class="aspect-square p-4 border-b border-neutral-200 flex items-center justify-center">
            <img class="max-w-full max-h-full object-contain" src={partner.content.logo.filename} alt={partner.content.name} />
          </div>
          <div class="p-3 text-center">
            <span class="font-bold text-sm group-hover:text-[var(--brand)] transition hyphens-auto" lang="nl">{partner.content.name}</span>
          </div>
        </a>
      </li>
    )}
  </ul>
</div>