---
import StoryblokComponent from '@storyblok/astro/StoryblokComponent.astro';
import { storyblokEditable, useStoryblokApi } from '@storyblok/astro';
import { Image } from "astro-preload/components";
import RichText from '../basics/RichText.astro';
const { blok, uuid } = Astro.props;

const storyblok_api = useStoryblokApi();

const vacancies = await storyblok_api.getAll("cdn/stories", {
  version: 'draft',
  starts_with: 'carriere/vacatures',
  content_type: 'vacancy',
  filter_query: {
    partner: {
      any_in_array: uuid
    }
  }
})
---

<main class="w-3/4 mx-auto py-8 min-h-[calc(100vh-160px)]" {...storyblokEditable(blok)}>
  <a href="/carriere/partners" class="text-[var(--brand-dark)] flex flex-row gap-2 group w-max">
    <i class="my-auto fas fa-arrow-left group-hover:-translate-x-1 transition-transform"></i>
    <span class="group-hover:underline">Terug naar het partneroverzicht</span>
  </a>

  <div class="rounded-xl border border-neutral-200 overflow-hidden mt-4">
    <div class="border-b border-neutral-200 w-full flex flex-row items-center gap-4 p-4">
      <Image class="aspect-square h-24 w-24 object-contain border border-neutral-200 rounded-lg p-2" url={blok.logo.filename} alt="" />
      <h1 class="font-bold text-3xl">{blok.name}</h1>
      <ul class="flex flex-row gap-4 ml-auto">
        {blok.buttons.map((button: any) => <li><StoryblokComponent blok={button} /></li>)}
      </ul>
    </div>
    <RichText class="p-6" content={blok.body} />
  </div>

  {!!vacancies.length && <>
    <div class="border-neutral-300 flex flex-row my-8">
      <div class="bg-neutral-300 h-px w-full my-auto"></div>
      <img src="/exclamation.svg" class="w-7" />
      <div class="bg-neutral-300 h-px w-full my-auto"></div>
    </div>
    <h2 class="text-2xl font-bold mb-4">Vacatures bij {blok.name}</h2>
    <ul class="grid grid-cols-4 gap-6">
      {vacancies.map((vacancy: any) => (
        <li>
          <a href={"/" + vacancy.full_slug} class="group flex flex-col h-full border border-neutral-200 rounded-xl overflow-hidden hover:-translate-y-1 hover:shadow-lg hover:border-[var(--brand)] transition">
            <div class="aspect-square p-4 border-b border-neutral-200 flex items-center justify-center">
              <Image class="max-w-full max-h-full object-contain" url={blok.logo.filename} />
            </div>
            <div class="p-4 flex flex-col gap-1 text-center flex-1">
              <span class="font-bold group-hover:text-[var(--brand)] transition">{vacancy.name}</span>
              <p class="text-sm text-neutral-600">{vacancy.content.short_text}</p>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </>}
</main>
