---
import { renderRichText } from "@storyblok/astro";
import { Image } from "astro-preload/components";
import RichText from "./basics/RichText.astro";

const { blok } = Astro.props;
---

<main class="grid grid-cols-5 w-4/5 mx-auto gap-8 my-12">
  <div class="flex flex-col col-span-3">
    <div class="border border-neutral-300 rounded-xl p-4">
      <h1 class="text-2xl font-bold mb-4">Sociale veiligheid bij Sticky</h1>
      <!-- <div id="vcp-body" lang="nl" set:html={renderRichText(blok.body)}></div> -->
      <div lang="nl" id="vcp-body">
        <RichText content={blok.body} />
      </div>
    </div>
    <div class="flex flex-row gap-8 py-8 px-4">
      <div class="w-1/3 my-auto text-center">
        Deel je verhaal anoniem via ons anoniem meldpunt:
        <a class="text-blue-500 hover:underline inline-block" href="https://voeljeveilig.svsticky.nl">voeljeveilig.svsticky.nl</a>.
      </div>
      <div class="flex flex-col py-4">
        <div class="bg-neutral-300 w-px h-full mx-auto"></div>
        <i class="my-auto py-2 text-xl text-neutral-600">Of</i>
        <div class="bg-neutral-300 w-px h-full mx-auto"></div>
      </div>
      <div class="flex flex-col gap-4 w-min grow">
        <p lang="nl" class="hyphens-auto text-center">Neem zelf contact op met een van onze vertrouwenscontactpersonen:</p>
        <ul class="flex flex-col gap-4 mx-auto">
          {blok.people.map(person => (
            <li class="grid grid-cols-[6rem_auto] gap-4">
              <Image url={person.photo.filename} class="rounded-full w-full h-auto aspect-square my-auto border border-neutral-300" />
              <div class="flex flex-col gap-2">
                <span class="w-full font-bold text-lg">{person.name}</span>
                <span class="flex flex-row gap-1 text-sm">
                  <i class="fas fa-envelope my-auto"></i>
                  {person.email}
                </span>
                <span class="flex flex-row gap-1 text-sm">
                  <i class="fas fa-phone my-auto"></i>
                  {person.phone}
                </span>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <div class="w-full col-span-2">
    <Image url={blok.poster.filename} class="w-full h-auto rounded-xl" />
  </div>
</main>

<style is:global>
  #vcp-body {
    hyphens: auto;
  }
</style>